# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Cache DB (Postgres) ---
CACHE_DB_NAME=app_cache                     # database Postgres will create inside the cache container
CACHE_DB_USER=app_user                      # username the api/sync services use to connect to the cache DB
CACHE_DB_PASSWORD=change_me                 # password for that user — replace with a real secret before running

# --- Source DB (your production/source database) — read only by the sync job ---
SOURCE_DB_HOST=your-source-db.example.com   # hostname or IP of the server hosting your real source database
SOURCE_DB_PORT=1433                         # port the source database listens on (1433 is SQL Server's default)
SOURCE_DB_NAME=your_database                # name of the source database to read tables from
SOURCE_DB_USER=your_readonly_user           # ideally a read-only account — the sync job never writes to the source
SOURCE_DB_PASSWORD=change_me                # password for that account — replace with a real secret before running

# --- Frontend build-time ---
# Path the React app calls; nginx proxies this to the api service (see frontend/nginx.conf)
VITE_API_URL=/api                           # relative path so the browser always calls the origin it was served from
